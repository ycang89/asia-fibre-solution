# Dev: Umi proxies `/api/*` from this app to Nest (see config/proxy.ts). Default target: http://localhost:3000
# No quotes around the URL.
API_PROXY_TARGET=http://localhost:3000

# Typical local dev: leave UMI_APP_API_ORIGIN unset/empty so requests go to same-origin `/api` and the dev proxy
# forwards to Nest. Setting UMI_APP_API_ORIGIN skips the proxy (browser → Nest directly; CORS must allow the UI origin).
#
# If you set it, use a bare URL with NO quotes (bad: UMI_APP_API_ORIGIN="http://localhost:3000" — some loaders keep
# the quote characters and break routing, producing paths like /user/"http://localhost:3000"/api/...).
# UMI_APP_API_ORIGIN=http://localhost:3000

# Production: when the SPA and API are on different hosts:
# UMI_APP_API_ORIGIN=https://api.example.com
