# Copy to .env (never commit .env). Values from Supabase Dashboard → API.
# Use the service role key only on the server; it bypasses Row Level Security.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Auth (email login used by Ant Design Pro → POST /api/login/account)
JWT_SECRET=change-me-to-a-long-random-string
LOGIN_DEMO_EMAIL=you@example.com
LOGIN_DEMO_PASSWORD=your-demo-password
# Optional: Pro `access` / menu role (default admin)
# LOGIN_DEMO_AUTHORITY=admin

# Optional
PORT=3000
